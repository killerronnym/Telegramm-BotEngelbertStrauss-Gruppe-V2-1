# Flask System Settings
FLASK_APP=web_dashboard.app
FLASK_ENV=production
SECRET_KEY=change_me_to_something_secure_in_production

# --- Database Connection ---
# Option 1: SQLite (Default, easy setup)
# DATABASE_URL=sqlite:///instance/app.db

# Option 2: MySQL / MariaDB (Recommended for Docker/Production)
# Use these discrete variables instead of a full DATABASE_URL 
# to ensure passwords with special characters (@, #, etc.) are handled safely.
DB_DRIVER=mysql+pymysql
DB_USER=dein_db_username
DB_PASSWORD=dein_sicheres_passwort
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bot_engine_db

# --- Telegram Bot Settings ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_id_here
