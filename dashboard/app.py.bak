@app.route("/id-finder", methods=["GET", "POST"])
def id_finder_dashboard():
    if request.method == "POST":
        action = request.form.get("action")

        if action == "start_bot":
            success, msg = start_id_finder_bot()
            flash(msg, "success" if success else "danger")
            return redirect(url_for("id_finder_dashboard"))

        if action == "stop_bot":
            success, msg = stop_id_finder_bot()
            flash(msg, "success" if success else "danger")
            return redirect(url_for("id_finder_dashboard"))

        if action == "clear_system_log":
            try:
                with open(ID_FINDER_BOT_LOG, "w", encoding="utf-8") as f:
                    f.write("")
                flash("System- & Fehler-Log erfolgreich geleert.", "success")
            except Exception as e:
                flash(f"Fehler beim Leeren des Logs: {e}", "danger")
            return redirect(url_for("id_finder_dashboard"))

        if action == "clear_command_log":
            try:
                with open(ID_FINDER_COMMAND_LOG, "w", encoding="utf-8") as f:
                    f.write("")
                flash("Befehls-Logbuch erfolgreich geleert.", "success")
            except Exception as e:
                flash(f"Fehler beim Leeren des Logs: {e}", "danger")
            return redirect(url_for("id_finder_dashboard"))

        if action == "save_config":
            was_running = is_id_finder_running()
            if was_running:
                stop_id_finder_bot()

            config = load_json(ID_FINDER_CONFIG_FILE, {})
            config["bot_token"] = (request.form.get("bot_token") or "").strip()

            mg_raw = (request.form.get("main_group_id") or "").strip()
            mg_int = _safe_int_or_none(mg_raw)
            config["main_group_id"] = mg_int if mg_int is not None else mg_raw

            ag_raw = (request.form.get("admin_group_id") or "").strip()
            ag_int = _safe_int_or_none(ag_raw)
            config["admin_group_id"] = ag_int if ag_int is not None else None

            topic_val = (request.form.get("admin_log_topic_id") or request.form.get("log_topic_id") or "").strip()
            topic_int = _safe_int_or_none(topic_val)
            config["admin_log_topic_id"] = topic_int if topic_int is not None else None
            config["log_topic_id"] = config["admin_log_topic_id"]

            config["delete_commands"] = _checkbox(request.form, "delete_commands")
            config["bot_message_cleanup_seconds"] = _safe_int(request.form.get("bot_message_cleanup_seconds"), 0) or 0

            _apply_checkbox_tristate(config, request.form, "message_logging_enabled", default_if_missing=True)
            _apply_checkbox_tristate(config, request.form, "message_logging_groups_only", default_if_missing=True)
            _apply_checkbox_tristate(config, request.form, "message_logging_ignore_commands", default_if_missing=True)
            _apply_checkbox_tristate(config, request.form, "message_logging_ignore_bots", default_if_missing=True)

            save_json(ID_FINDER_CONFIG_FILE, config)
            flash("ID Finder Konfiguration gespeichert.", "success")

            if was_running:
                start_id_finder_bot()
                flash("ID Finder Bot neu gestartet.", "info")

            return redirect(url_for("id_finder_dashboard"))

        return redirect(url_for("id_finder_dashboard"))

    config = load_json(ID_FINDER_CONFIG_FILE, {})
    system_logs = get_bot_logs(ID_FINDER_BOT_LOG)
    command_logs = get_bot_logs(ID_FINDER_COMMAND_LOG)

    user_registry = load_user_registry_list()

    q = (request.args.get("q") or "").strip()
    user_registry_filtered = filter_users(user_registry, q)

    return render_template(
        "id_finder_dashboard.html",
        config=config,
        is_running=is_id_finder_running(),
        system_logs=system_logs,
        command_logs=command_logs,
        user_registry=user_registry_filtered,
        user_registry_count=len(user_registry_filtered),
        search_query=q,
        bot_status=build_bot_status(),
        user={},
    )


