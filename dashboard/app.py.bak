# ✅ User Registry Loader fürs Dashboard/Admin Panel
def load_user_registry_list():
    """
    Returns list of users for dashboard.
    Accepts formats:
      A) {"users": {"123": {...}, ...}}
      B) {"users": [ {...}, {...} ]}
      C) [ {...}, {...} ]
      D) {"123": {...}, "456": {...}}  (fallback)
    """
    try:
        if not os.path.exists(USER_REGISTRY_FILE):
            log.info("User Registry Datei existiert nicht: %s", USER_REGISTRY_FILE)
            return []

        raw = load_json(USER_REGISTRY_FILE, default_data={})
        users = None

        if isinstance(raw, list):
            users = raw
        elif isinstance(raw, dict):
            users = raw.get("users")
            if users is None:
                users = raw

        out = []

        if isinstance(users, dict):
            for uid_str, entry in users.items():
                if not isinstance(entry, dict):
                    entry = {}
                chat_ids_raw = entry.get("chat_ids", []) or []
                if not isinstance(chat_ids_raw, list):
                    chat_ids_raw = [chat_ids_raw] if chat_ids_raw else []

                last_seen_raw = entry.get("last_seen", "") or ""
                first_seen_raw = entry.get("first_seen", "") or ""
                last_dt = _parse_dt(last_seen_raw)
                first_dt = _parse_dt(first_seen_raw)

                out.append(
                    {
                        "id": str(uid_str),
                        "username": entry.get("username", "") or "",
                        "full_name": entry.get("full_name", "") or "",
                        "last_seen_raw": last_seen_raw,
                        "first_seen_raw": first_seen_raw,
                        "last_seen": _format_dt_de(last_dt, time_first=True) if last_dt else last_seen_raw,
                        "first_seen": _format_dt_de(first_dt, time_first=True) if first_dt else first_seen_raw,
                        "is_bot": bool(entry.get("is_bot", False)),
                        "chat_ids_raw": chat_ids_raw,
                        "chat_ids": chat_ids_raw,
                        "avatar_url": f"/tg/avatar/{str(uid_str)}",
                        "_sort_dt": last_dt,
                    }
                )

        elif isinstance(users, list):
            for entry in users:
                if not isinstance(entry, dict):
                    continue
                chat_ids_raw = entry.get("chat_ids", []) or []
                if not isinstance(chat_ids_raw, list):
                    chat_ids_raw = [chat_ids_raw] if chat_ids_raw else []

                last_seen_raw = entry.get("last_seen", "") or ""
                first_seen_raw = entry.get("first_seen", "") or ""
                last_dt = _parse_dt(last_seen_raw)
                first_dt = _parse_dt(first_seen_raw)

                uid = str(entry.get("id", "") or entry.get("user_id", "") or "")
                out.append(
                    {
                        "id": uid,
                        "username": entry.get("username", "") or "",
                        "full_name": entry.get("full_name", "") or entry.get("name", "") or "",
                        "last_seen_raw": last_seen_raw,
                        "first_seen_raw": first_seen_raw,
                        "last_seen": _format_dt_de(last_dt, time_first=True) if last_dt else last_seen_raw,
                        "first_seen": _format_dt_de(first_dt, time_first=True) if first_dt else first_seen_raw,
                        "is_bot": bool(entry.get("is_bot", False)),
                        "chat_ids_raw": chat_ids_raw,
                        "chat_ids": chat_ids_raw,
                        "avatar_url": f"/tg/avatar/{uid}",
                        "_sort_dt": last_dt,
                    }
                )

        for u in out:
            c = u.get("chat_ids", [])
            if isinstance(c, (list, tuple, set)):
                u["chat_ids"] = ", ".join([str(x) for x in c])
            else:
                u["chat_ids"] = str(c) if c else ""

        def _sort_key(x):
            dt = x.get("_sort_dt")
            if isinstance(dt, datetime):
                try:
                    return dt.timestamp()
                except Exception:
                    return 0
            return 0

        out.sort(key=_sort_key, reverse=True)

        for u in out:
            if "_sort_dt" in u:
                del u["_sort_dt"]

        log.info("User Registry geladen: %s | users=%s", USER_REGISTRY_FILE, len(out))
        return out

    except Exception as e:
        log.warning("User Registry konnte nicht geladen werden: %s", e)
        return []


def filter_users(users, q: str):
    if not q:
        return users
    qq = str(q).strip().lower()
    if not qq:
        return users

    out = []
    for u in users:
        uid = str(u.get("id", "")).lower()
        un = str(u.get("username", "")).lower()
        fn = str(u.get("full_name", "")).lower()
        if (qq in uid) or (qq in un) or (qq in fn):
            out.append(u)
    return out


def _user_message_files(uid: str):
    base = os.path.join(USER_MESSAGE_DIR, f"{uid}.jsonl")
    files = []
    if os.path.exists(base):
        files.append(base)
    for i in range(1, 10):
        p = f"{base}.{i}"
        if os.path.exists(p):
            files.append(p)
    return files  # newest-first


def load_user_messages(uid: str, limit: int = 200, q: str = "", media_only: bool = False):
    uid = str(uid).strip()
    if not uid:
        return []

    limit = int(limit) if str(limit).isdigit() else 200
    if limit <= 0:
        limit = 200
    if limit > 2000:
        limit = 2000

    qq = (q or "").strip().lower()
    out = []

    for fp in _user_message_files(uid):
        lines = _tail_text_file(fp, max_lines=3000)
        for line in reversed(lines):
            line = (line or "").strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except Exception:
                continue

            has_media = bool(obj.get("has_media")) or bool(obj.get("media"))
            if media_only and not has_media:
                continue

            if qq:
                t = str(obj.get("text", "")).lower()
                mk = str((obj.get("media") or {}).get("kind", "")).lower()
                ct = str(obj.get("chat_title", "")).lower()
                if (qq not in t) and (qq not in mk) and (qq not in ct):
                    continue

            out.append(obj)
            if len(out) >= limit:
                return out

    return out


def _extract_reactions_total(m: dict) -> int:
    if not isinstance(m, dict):
        return 0

    for k in ("reactions_total", "reaction_total", "likes", "like_count", "reaction_count"):
        v = m.get(k)
        if isinstance(v, (int, float)):
            return int(v)

    r = m.get("reactions")
    if isinstance(r, dict):
        for k in ("total", "total_count", "count"):
            v = r.get(k)
            if isinstance(v, (int, float)):
                return int(v)
    if isinstance(r, list):
        total = 0
        for x in r:
            if isinstance(x, dict) and isinstance(x.get("count"), (int, float)):
                total += int(x["count"])
        return total

    return 0


def _extract_reactions_breakdown(m: dict, reg_map: dict = None) -> list:
    reg_map = reg_map or {}
    out = []

    if not isinstance(m, dict):
        return out

    detail = m.get("reactions_detail") or m.get("reaction_details") or m.get("reaction_updates") or m.get("reactions_updates") or m.get("reactions_updates")
    if isinstance(detail, list) and detail:
        bucket = {}
        for x in detail:
            if not isinstance(x, dict):
                continue
            emoji = (x.get("emoji") or x.get("reaction") or x.get("type") or "").strip()
            if not emoji:
                continue
            uid = x.get("user_id") or x.get("from_user_id") or x.get("from_id") or x.get("sender_id")
            uid = str(uid).strip() if uid is not None else ""
            if emoji not in bucket:
                bucket[emoji] = {"emoji": emoji, "count": 0, "users": []}
            bucket[emoji]["count"] += 1
            if uid:
                u = reg_map.get(uid) or {}
                name = (u.get("full_name") or u.get("name") or "").strip()
                username = (u.get("username") or "").strip()
                label = name or (f"@{username}" if username else uid)
                if label not in bucket[emoji]["users"]:
                    bucket[emoji]["users"].append(label)
        out = list(bucket.values())
        out.sort(key=lambda x: x.get("count", 0), reverse=True)
        return out

    r = m.get("reactions")
    if isinstance(r, list) and r:
        for x in r:
            if not isinstance(x, dict):
                continue
            emoji = (x.get("emoji") or x.get("reaction") or x.get("type") or "").strip()
            cnt = x.get("count")
            if emoji and isinstance(cnt, (int, float)):
                out.append({"emoji": emoji, "count": int(cnt), "users": []})
        out.sort(key=lambda x: x.get("count", 0), reverse=True)
        return out

    if isinstance(r, dict):
        items = r.get("items") or r.get("list") or r.get("reactions") or []
        if isinstance(items, list):
            for x in items:
                if not isinstance(x, dict):
                    continue
                emoji = (x.get("emoji") or x.get("reaction") or x.get("type") or "").strip()
                cnt = x.get("count") or x.get("total_count") or x.get("votes")
                if emoji and isinstance(cnt, (int, float)):
                    out.append({"emoji": emoji, "count": int(cnt), "users": []})
            out.sort(key=lambda x: x.get("count", 0), reverse=True)
            return out

    return out


def _extract_likes_given_in_message(m: dict) -> list:
    if not isinstance(m, dict):
        return []
    detail = m.get("reactions_detail") or m.get("reaction_details") or m.get("reaction_updates") or m.get("reactions_updates")
    if not isinstance(detail, list) or not detail:
        return []
    out = []
    for x in detail:
        if not isinstance(x, dict):
            continue
        uid = x.get("user_id") or x.get("from_user_id") or x.get("from_id") or x.get("sender_id")
        if uid is None:
            continue
        s = str(uid).strip()
        if s:
            out.append(s)
    return out


def _msg_to_template(obj: dict, reg_map: dict = None) -> dict:
    if not isinstance(obj, dict):
        return {}

    reg_map = reg_map or {}

    media = obj.get("media") or {}
    has_media = bool(obj.get("has_media")) or bool(media)

    msg_type = "text"
    if has_media:
        msg_type = str(media.get("kind") or obj.get("type") or "media")

    file_id = (media.get("file_id") or obj.get("file_id") or "").strip()
    likes_total = _extract_reactions_total(obj)
    reactions_breakdown = _extract_reactions_breakdown(obj, reg_map=reg_map)

    out = {
        "ts": obj.get("ts") or "",
        "type": msg_type,
        "text": obj.get("text") or "",
        "caption": obj.get("caption") or media.get("caption") or "",
        "chat_id": obj.get("chat_id") or "",
        "message_id": obj.get("message_id") or "",
        "file_name": media.get("file_name") or obj.get("file_name") or "",
        "mime_type": media.get("mime_type") or obj.get("mime_type") or "",
        "file_id": file_id,
        "media_url": (f"/tg/file/{file_id}" if file_id else ""),
        "likes_total": int(likes_total or 0),
        "reactions": reactions_breakdown,
        "raw": None,
    }

    try:
        out["raw"] = json.dumps(obj, ensure_ascii=False, indent=2)
    except Exception:
        out["raw"] = None

    return out


def _build_user_stats(messages: list) -> dict:
    now = datetime.now()
    last_24h = 0
    last_7d = 0
    hourly = {h: 0 for h in range(24)}
    likes_received = 0

    for m in messages or []:
        dt = _parse_dt((m or {}).get("ts"))
        if not dt:
            continue
        try:
            dt_naive = dt.replace(tzinfo=None) if dt.tzinfo is not None else dt
        except Exception:
            dt_naive = dt

        if dt_naive >= now - timedelta(hours=24):
            last_24h += 1
        if dt_naive >= now - timedelta(days=7):
            last_7d += 1
        try:
            hourly[int(dt_naive.hour)] += 1
        except Exception:
            pass

        likes_received += _extract_reactions_total(m)

    return {
        "total_messages": len(messages or []),
        "last_24h": last_24h,
        "last_7d": last_7d,
        "hourly": hourly,
        "likes_received": int(likes_received),
    }


def delete_user_hierarchy(
    uid: str,
    *,
    delete_registry=True,
    delete_messages=True,
    delete_moderation=True,
    delete_username_cache=True,
):
    uid = str(uid).strip()
    if not uid:
        return False, "Keine User-ID."

    changed_any = False

    if delete_registry:
        data = load_json(USER_REGISTRY_FILE, {})
        changed = False

        if isinstance(data, list):
            before = len(data)
            data = [x for x in data if str((x or {}).get("id") or (x or {}).get("user_id") or "") != uid]
            changed = (len(data) != before)

        elif isinstance(data, dict):
            users = data.get("users")

            if isinstance(users, dict):
                if uid in users:
                    del users[uid]
                    changed = True

            elif isinstance(users, list):
                before = len(users)
                data["users"] = [x for x in users if str((x or {}).get("id") or (x or {}).get("user_id") or "") != uid]
                changed = (len(data["users"]) != before)

            else:
                if uid in data:
                    del data[uid]
                    changed = True

        if changed:
            save_json(USER_REGISTRY_FILE, data)
            changed_any = True

    if delete_messages:
        base = os.path.join(USER_MESSAGE_DIR, f"{uid}.jsonl")
        removed = False
        for p in [base] + [f"{base}.{i}" for i in range(1, 11)]:
            if os.path.exists(p):
                try:
                    os.remove(p)
                    removed = True
                except Exception:
                    pass
        changed_any = changed_any or removed

    if delete_moderation:
        mod = load_json(MODERATION_DATA_FILE, {})
        if isinstance(mod, dict) and uid in mod:
            del mod[uid]
            save_json(MODERATION_DATA_FILE, mod)
            changed_any = True

    if delete_username_cache:
        cache = load_json(USERNAME_CACHE_FILE, {})
        if isinstance(cache, dict):
            changed = False
            for k in list(cache.keys()):
                try:
                    if str(cache.get(k)) == uid:
                        del cache[k]
                        changed = True
                except Exception:
                    pass
            if changed:
                save_json(USERNAME_CACHE_FILE, cache)
                changed_any = True

    return changed_any, ("✅ User-Hierarchie gelöscht." if changed_any else "ℹ️ Nichts zu löschen gefunden.")


# -------------------------------------------------------------------
# ✅ REWORK: Group Activity (schnell + kompatibel)
# -------------------------------------------------------------------
def _iter_message_files():
    if not os.path.isdir(USER_MESSAGE_DIR):
        return []
    files = []
    for fn in os.listdir(USER_MESSAGE_DIR):
        if not (fn.endswith(".jsonl") or ".jsonl." in fn):
            continue
        files.append(os.path.join(USER_MESSAGE_DIR, fn))
    return files


def _extract_user_id_from_msg(m: dict):
    for k in ("from_user_id", "user_id", "from_id", "sender_id", "uid"):
        v = m.get(k)
        if v is not None and str(v).strip():
            return str(v).strip()
    return ""


def build_group_activity(days: int = 30, chat_id=None) -> dict:
    days = int(days) if str(days).isdigit() else 30
    if days < 1:
        days = 1
    if days > 365:
        days = 365

    chat_id_raw = (str(chat_id).strip() if chat_id is not None else "")
    chat_id_filter = None
    if chat_id_raw != "":
        chat_id_filter = chat_id_raw

    now = _now()
    cutoff = now - timedelta(days=days)
    cutoff_naive = cutoff.replace(tzinfo=None) if cutoff.tzinfo is not None else cutoff

    start_date = (now - timedelta(days=days - 1)).date()
    labels = [(start_date + timedelta(days=i)).isoformat() for i in range(days)]

    per_hour = [0] * 24
    per_weekday = [0] * 7
    timeline_map = defaultdict(int)

    per_user = defaultdict(lambda: {
        "user_id": "",
        "username": "",
        "full_name": "",
        "messages": 0,
        "media": 0,
        "likes_received": 0,
        "likes_given": 0,
        "last_seen": None,
        "daily": defaultdict(int),
    })

    per_chat = defaultdict(int)

    total = 0
    media_shared = 0
    total_reactions_received = 0
    total_reactions_given = 0

    reg_list = load_user_registry_list()
    reg_map = {str(u.get("id")): u for u in reg_list if u.get("id")}

    MAX_LINES_PER_FILE = 12000

    for fp in _iter_message_files():
        lines = _tail_text_file(fp, max_lines=MAX_LINES_PER_FILE)
        for line in lines:
            line = (line or "").strip()
            if not line:
                continue
            try:
                m = json.loads(line)
            except Exception:
                continue

            dt = _parse_dt(m.get("ts"))
            if not dt:
                continue
            try:
                dt_naive = dt.replace(tzinfo=None) if dt.tzinfo is not None else dt
            except Exception:
                dt_naive = dt

            if dt_naive < cutoff_naive:
                continue

            cid = m.get("chat_id")
            if chat_id_filter is not None:
                if cid is None:
                    continue
                if str(cid) != chat_id_filter:
                    continue

            author_uid = _extract_user_id_from_msg(m)
            if not author_uid:
                continue

            total += 1

            try:
                per_hour[int(dt_naive.hour)] += 1
            except Exception:
                pass
            try:
                per_weekday[int(dt_naive.weekday())] += 1
            except Exception:
                pass

            dkey = dt_naive.date().isoformat()
            if dkey in labels:
                timeline_map[dkey] += 1

            if cid is not None:
                per_chat[str(cid)] += 1

            has_media = bool(m.get("has_media")) or bool(m.get("media"))
            if has_media:
                media_shared += 1

            likes_received = _extract_reactions_total(m)
            total_reactions_received += likes_received

            reactors = _extract_likes_given_in_message(m)
            if reactors:
                for rid in reactors:
                    per_user[rid]["user_id"] = rid
                    per_user[rid]["likes_given"] += 1
                    total_reactions_given += 1

            u = per_user[author_uid]
            u["user_id"] = author_uid
            u["messages"] += 1
            u["media"] += 1 if has_media else 0
            u["likes_received"] += likes_received

            username = m.get("username") or ""
            full_name = m.get("full_name") or m.get("name") or ""

            if author_uid in reg_map:
                if not username:
                    username = reg_map[author_uid].get("username", "") or ""
                if not full_name:
                    full_name = reg_map[author_uid].get("full_name", "") or ""

            u["username"] = username
            u["full_name"] = full_name

            prev = u["last_seen"]
            if prev is None or dt_naive > prev:
                u["last_seen"] = dt_naive

            if dkey in labels:
                u["daily"][dkey] += 1

    total_arr = [int(timeline_map.get(d, 0)) for d in labels]

    busiest_day = None
    if timeline_map:
        busiest_day = max(timeline_map.items(), key=lambda x: x[1])[0]

    leaderboard_list = sorted(per_user.values(), key=lambda x: x.get("messages", 0), reverse=True)
    leaderboard = []
    user_series = {}

    for idx, u in enumerate(leaderboard_list[:20], start=1):
        uid = u["user_id"]
        avatar_url = reg_map.get(uid, {}).get("avatar_url") or f"/tg/avatar/{uid}"
        leaderboard.append({
            "rank": idx,
            "user_id": uid,
            "username": u.get("username", ""),
            "name": u.get("full_name", ""),
            "messages": int(u.get("messages", 0)),
            "media": int(u.get("media", 0)),
            "likes_received": int(u.get("likes_received", 0)),
            "likes_given": int(u.get("likes_given", 0)),
            "avatar_url": avatar_url,
        })
        user_series[uid] = [int(u["daily"].get(d, 0)) for d in labels]

    top_contributor = None
    most_liked_user = None
    if leaderboard:
        top_contributor = leaderboard[0].get("name") or (f"@{leaderboard[0].get('username')}" if leaderboard[0].get("username") else leaderboard[0].get("user_id"))
        most = max(leaderboard, key=lambda x: x.get("likes_received", 0))
        most_liked_user = most.get("name") or (f"@{most.get('username')}" if most.get("username") else most.get("user_id"))

    top_chat = None
    if per_chat:
        cid, cnt = max(per_chat.items(), key=lambda x: x[1])
        top_chat = {"chat_id": str(cid), "messages": int(cnt)}

    peak_hour = max(range(24), key=lambda h: per_hour[h]) if total > 0 else None
    peak_weekday = max(range(7), key=lambda d: per_weekday[d]) if total > 0 else None

    recently_active = []
    recent_sorted = sorted(per_user.values(), key=lambda x: x["last_seen"] or datetime.min, reverse=True)[:10]
    for u in recent_sorted:
        dt_last = u["last_seen"]
        uid = u["user_id"]
        recently_active.append({
            "user_id": uid,
            "username": u.get("username", ""),
            "name": u.get("full_name", ""),
            "last_seen": dt_last.isoformat() if isinstance(dt_last, datetime) else None,
            "avatar_url": reg_map.get(uid, {}).get("avatar_url") or f"/tg/avatar/{uid}",
        })

    meta = {
        "days": days,
        "chat_id": chat_id_filter,
        "total_messages": int(total),
        "active_users": int(len(per_user)),
        "media_shared": int(media_shared),
        "total_reactions_received": int(total_reactions_received),
        "total_reactions_given": int(total_reactions_given),
        "peak_hour": peak_hour,
        "peak_weekday": peak_weekday,
        "busiest_day": busiest_day,
        "top_contributor": top_contributor,
        "most_liked_user": most_liked_user,
        "top_chat": top_chat,
    }

    meta_compat = {
        "days": meta["days"],
        "chat_id": meta["chat_id"],
        "totalMessages": meta["total_messages"],
        "activeUsers": meta["active_users"],
        "mediaShared": meta["media_shared"],
        "totalReactions": meta["total_reactions_received"],
        "busiestDay": meta["busiest_day"],
        "topContributor": meta["top_contributor"],
        "mostLikedUser": meta["most_liked_user"],
        "topChat": meta["top_chat"],
    }

    timeline_list = [{"date": d, "count": int(timeline_map.get(d, 0))} for d in labels]

    kpis = {
        "total_messages": int(total),
        "active_users": int(len(per_user)),
        "busiest_day": busiest_day,
        "media_shared": int(media_shared),
        "total_reactions_received": int(total_reactions_received),
        "total_reactions_given": int(total_reactions_given),
        "top_contributor": top_contributor or "—",
        "most_liked_user": most_liked_user or "—",
        "top_chat": top_chat or "—",
    }

    return {
        "ok": True,
        "meta": meta_compat,
        "per_hour": per_hour,
        "per_weekday": per_weekday,
        "timeline": timeline_list,
        "leaderboard": leaderboard,
        "kpis": kpis,
        "timeline2": {"labels": labels, "total": total_arr},
        "timeline_series": {"labels": labels, "total": total_arr},
        "busiest_hours": per_hour,
        "busiest_days": per_weekday,
        "user_series": user_series,
        "recently_active": recently_active,
    }


