@app.route("/outfit-bot/save-config", methods=["POST"])
def outfit_bot_save_config():
    was_running = is_outfit_bot_running()
    if was_running:
        stop_outfit_bot()

    config = load_json(OUTFIT_BOT_CONFIG_FILE, {})
    form = request.form

    post_time = _time_from_form(form, "POST_TIME", fallback=(config.get("POST_TIME") or "18:00"))
    winner_time = _time_from_form(form, "WINNER_TIME", fallback=(config.get("WINNER_TIME") or "22:00"))

    config.update(
        {
            "BOT_TOKEN": (form.get("BOT_TOKEN") or "").strip(),
            "CHAT_ID": (form.get("CHAT_ID") or "").strip(),
            "TOPIC_ID": (form.get("TOPIC_ID") or "").strip() or None,
            "POST_TIME": post_time,
            "WINNER_TIME": winner_time,
            "DUEL_TYPE": (form.get("DUEL_TYPE") or "tie_breaker").strip(),
            "DUEL_DURATION_MINUTES": _safe_int(form.get("DUEL_DURATION_MINUTES"), 60) or 60,
            "TEMPORARY_MESSAGE_DURATION_SECONDS": _safe_int(form.get("TEMPORARY_MESSAGE_DURATION_SECONDS"), 30) or 30,
        }
    )

    config["AUTO_POST_ENABLED"] = "AUTO_POST_ENABLED" in form
    config["DUEL_MODE"] = "DUEL_MODE" in form

    admin_ids_str = form.get("ADMIN_USER_IDS", "") or ""
    config["ADMIN_USER_IDS"] = [int(x.strip()) for x in admin_ids_str.split(",") if x.strip().isdigit()]

    save_json(OUTFIT_BOT_CONFIG_FILE, config)
    flash("Konfiguration gespeichert!", "success")

    if was_running:
        start_outfit_bot()
        flash("Bot wird mit neuer Konfiguration neu gestartet.", "info")

    return redirect(url_for("outfit_bot_dashboard"))


