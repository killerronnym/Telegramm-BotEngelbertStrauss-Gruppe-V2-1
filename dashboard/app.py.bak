@app.route("/id-finder/user/<user_id>")
def id_finder_user_detail(user_id):
    uid = str(user_id).strip()
    if not uid:
        flash("Ungültige User-ID.", "danger")
        return redirect(url_for("id_finder_dashboard"))

    users = load_user_registry_list()
    user = next((u for u in users if str(u.get("id")) == uid), None)

    if not user:
        user = {
            "id": uid,
            "username": "",
            "full_name": "",
            "first_seen": "",
            "last_seen": "",
            "chat_ids": "",
            "is_bot": False,
            "avatar_url": f"/tg/avatar/{uid}",
        }
    else:
        user["avatar_url"] = user.get("avatar_url") or f"/tg/avatar/{uid}"

    q = (request.args.get("q") or "").strip()

    old_media_only = str(request.args.get("media_only") or "0").strip().lower() in ("1", "true", "yes", "on")
    filter_type = (request.args.get("type") or ("media" if old_media_only else "all")).strip().lower()
    if filter_type not in ("all", "text", "media"):
        filter_type = "all"

    page = _safe_int(request.args.get("page"), 1) or 1
    if page < 1:
        page = 1

    page_size = 50
    need = min(2000, max(200, page * page_size))
    raw_msgs = load_user_messages(uid, limit=need, q=q, media_only=(filter_type == "media"))

    reg_map = {str(u.get("id")): u for u in (users or []) if isinstance(u, dict) and u.get("id")}
    msgs = [_msg_to_template(x, reg_map=reg_map) for x in (raw_msgs or []) if isinstance(x, dict)]

    if filter_type == "text":
        msgs = [m for m in msgs if (m.get("type") == "text")]

    total = len(msgs)
    start = (page - 1) * page_size
    end = start + page_size
    msgs_page = msgs[start:end]
    has_prev = page > 1
    has_next = end < total

    stats = _build_user_stats(raw_msgs)

    try:
        return render_template(
            "id_finder_user_detail.html",
            user=user,
            messages=msgs_page,
            stats=stats,
            q=q,
            filter_type=filter_type,
            page=page,
            page_size=page_size,
            has_prev=has_prev,
            has_next=has_next,
            bot_status=build_bot_status(),
        )
    except TemplateNotFound:
        html_page = """
        <html><head><meta charset="utf-8"><title>User Verlauf</title></head>
        <body style="font-family: Arial, sans-serif; padding: 20px;">
          <h2>👤 User Detail</h2>
          <div style="display:flex; gap:12px; align-items:center;">
            <img src="{{user.get('avatar_url')}}" style="width:56px;height:56px;border-radius:50%;object-fit:cover;border:1px solid #ddd;">
            <div>
              <p style="margin:0;"><b>User-ID:</b> {{user.get('id')}}</p>
              <p style="margin:0;"><b>Username:</b> @{{user.get('username')}}</p>
              <p style="margin:0;"><b>Name:</b> {{user.get('full_name')}}</p>
              <p style="margin:0;"><b>Last Seen:</b> {{user.get('last_seen')}}</p>
            </div>
          </div>

          <form method="get" style="margin: 10px 0;">
            <input name="q" placeholder="Suche im Verlauf..." value="{{q}}" />
            <select name="type">
              <option value="all" {% if filter_type=='all' %}selected{% endif %}>Alle</option>
              <option value="text" {% if filter_type=='text' %}selected{% endif %}>Nur Text</option>
              <option value="media" {% if filter_type=='media' %}selected{% endif %}>Nur Media</option>
            </select>
            <button type="submit">Filtern</button>
          </form>

          <hr>
          <h3>🧾 Letzte Nachrichten ({{messages|length}})</h3>
          {% for m in messages %}
            <div style="padding:10px; border:1px solid #ddd; border-radius:8px; margin:10px 0;">
              <div style="color:#666;"><b>{{m.get('ts')}}</b> | chat_id={{m.get('chat_id')}} | msg_id={{m.get('message_id')}}</div>
              {% if m.get('text') %}
                <div style="margin-top:6px;">{{m.get('text')}}</div>
              {% endif %}
              {% if m.get('caption') %}
                <div style="margin-top:6px;"><b>Caption:</b> {{m.get('caption')}}</div>
              {% endif %}

              {% if m.get('likes_total',0) %}
                <div style="margin-top:6px;"><b>Likes:</b> {{m.get('likes_total')}}</div>
              {% endif %}

              {% if m.get('reactions') %}
                <div style="margin-top:6px;">
                  <b>Reactions:</b>
                  <ul>
                  {% for r in m.get('reactions') %}
                    <li>{{r.get('emoji')}} × {{r.get('count')}}{% if r.get('users') %} — {{r.get('users')|join(', ')}}{% endif %}</li>
                  {% endfor %}
                  </ul>
                </div>
              {% endif %}

              {% if m.get('media_url') %}
                <div style="margin-top:6px;">
                  <b>Media:</b> {{m.get('type')}} —
                  <a href="{{m.get('media_url')}}" target="_blank">öffnen</a>
                </div>
              {% endif %}
            </div>
          {% endfor %}
          <p><a href="/id-finder">← zurück</a></p>
        </body></html>
        """
        return render_template_string(
            html_page,
            user=user,
            messages=msgs_page,
            q=q,
            filter_type=filter_type,
        )


@app.route("/id-finder/api/users")
def id_finder_api_users():
    users = load_user_registry_list()
    q = (request.args.get("q") or "").strip()
    users = filter_users(users, q)
    return jsonify({"ok": True, "count": len(users), "users": users})


@app.route("/id-finder/api/users/<user_id>/messages")
def id_finder_api_user_messages(user_id):
    uid = str(user_id).strip()
    limit = _safe_int(request.args.get("limit"), 200) or 200
    q = (request.args.get("q") or "").strip()
    media_only = str(request.args.get("media_only") or "0").strip().lower() in ("1", "true", "yes", "on")
    msgs_raw = load_user_messages(uid, limit=limit, q=q, media_only=media_only)

    reg = load_user_registry_list()
    reg_map = {str(u.get("id")): u for u in (reg or []) if isinstance(u, dict) and u.get("id")}
    msgs = [_msg_to_template(x, reg_map=reg_map) for x in (msgs_raw or []) if isinstance(x, dict)]

    return jsonify({"ok": True, "user_id": uid, "count": len(msgs), "messages": msgs})


# ✅ REWORK: Analytics liefert zusätzlich `stats` (für Template) + bleibt kompatibel
@app.route("/id-finder/analytics", methods=["GET"])
def id_finder_analytics():
    users = load_user_registry_list()

    now = datetime.now()
    seen_24h = 0
    seen_7d = 0

    chat_counter = {}
    unique_chats = set()

    most_recent_user = None
    most_recent_dt = None

    for u in users:
        dt = _parse_dt(u.get("last_seen_raw") or u.get("last_seen"))
        if dt:
            try:
                dt_naive = dt.replace(tzinfo=None) if dt.tzinfo is not None else dt
            except Exception:
                dt_naive = dt

            if dt_naive >= now - timedelta(hours=24):
                seen_24h += 1
            if dt_naive >= now - timedelta(days=7):
                seen_7d += 1

            if most_recent_dt is None or dt_naive > most_recent_dt:
                most_recent_dt = dt_naive
                most_recent_user = u

        for cid in (u.get("chat_ids_raw") or []):
            try:
                cidi = int(cid)
            except Exception:
                continue
            unique_chats.add(cidi)
            chat_counter[cidi] = chat_counter.get(cidi, 0) + 1

    top_chats = sorted(
        [{"chat_id": str(k), "users": int(v)} for k, v in chat_counter.items()],
        key=lambda x: x["users"],
        reverse=True,
    )

    top_chats_tuples = sorted(chat_counter.items(), key=lambda x: x[1], reverse=True)
    top_chats_tuples = [(str(cid), int(cnt)) for cid, cnt in top_chats_tuples[:20]]

    last_contact_de = _format_dt_de(most_recent_dt, time_first=True) if most_recent_dt else None
    last_contact_str = (most_recent_user or {}).get("last_seen_raw") if most_recent_user else None

    stats = {
        "total_users": len(users),
        "unique_chats": len(unique_chats),
        "top_chats": top_chats_tuples,
        "most_recent_user": most_recent_user,
        "last_contact_de": last_contact_de,
        "seen_24h": seen_24h,
        "seen_7d": seen_7d,
    }

    return render_template(
        "id_finder_analytics.html",
        stats=stats,
        total_users=len(users),
        user_registry_count=len(users),
        registry_count=len(users),
        seen_24h=seen_24h,
        seen_7d=seen_7d,
        unique_chat_ids=len(unique_chats),
        unique_chats=len(unique_chats),
        last_contact=last_contact_str,
        last_contact_de=last_contact_de,
        last_seen=last_contact_str,
        users=users,
        user_registry=users,
        registry_users=users,
        top_chats=top_chats,
        messages_by_hour=[],
        top_message_users=[],
        bot_status=build_bot_status(),
    )


