@app.route("/id-finder/user-registry/delete", methods=["POST"])
def id_finder_user_registry_delete():
    uid = (request.form.get("user_id") or "").strip()
    if not uid:
        flash("Fehler: Keine User-ID angegeben.", "danger")
        return redirect(url_for("id_finder_admin_panel"))

    data = load_json(USER_REGISTRY_FILE, {})
    changed = False

    if isinstance(data, list):
        before = len(data)
        data = [x for x in data if str((x or {}).get("id") or (x or {}).get("user_id") or "") != uid]
        changed = (len(data) != before)

    elif isinstance(data, dict):
        users = data.get("users")

        if isinstance(users, dict):
            if uid in users:
                del users[uid]
                changed = True

        elif isinstance(users, list):
            before = len(users)
            data["users"] = [x for x in users if str((x or {}).get("id") or (x or {}).get("user_id") or "") != uid]
            changed = (len(data["users"]) != before)

        else:
            if uid in data:
                del data[uid]
                changed = True

    if changed:
        save_json(USER_REGISTRY_FILE, data)
        flash(f"✅ User {uid} aus der Registry gelöscht.", "success")
    else:
        flash("ℹ️ User nicht in der Registry gefunden.", "warning")

    ref = request.referrer or ""
    if "/id-finder" in ref:
        return redirect(ref)
    return redirect(url_for("id_finder_admin_panel"))


@app.route("/id-finder/user/delete-hierarchy", methods=["POST"])
def id_finder_user_delete_hierarchy():
    uid = (request.form.get("user_id") or "").strip()
    if not uid:
        flash("Fehler: Keine User-ID angegeben.", "danger")
        return redirect(url_for("id_finder_admin_panel"))

    delete_registry = ("delete_registry" in request.form) or (request.form.get("delete_registry") == "1")
    delete_messages = ("delete_messages" in request.form) or (request.form.get("delete_messages") == "1")
    delete_moderation = ("delete_moderation" in request.form) or (request.form.get("delete_moderation") == "1")
    delete_cache = ("delete_cache" in request.form) or (request.form.get("delete_cache") == "1")

    if not any([delete_registry, delete_messages, delete_moderation, delete_cache]):
        delete_registry = delete_messages = delete_moderation = delete_cache = True

    ok, msg = delete_user_hierarchy(
        uid,
        delete_registry=delete_registry,
        delete_messages=delete_messages,
        delete_moderation=delete_moderation,
        delete_username_cache=delete_cache,
    )
    flash(msg, "success" if ok else "warning")

    ref = request.referrer or ""
    if "/id-finder/user/" in ref:
        return redirect(ref)
    return redirect(url_for("id_finder_admin_panel"))


@app.route("/id-finder/add-admin", methods=["POST"])
def id_finder_add_admin():
    admin_id = (request.form.get("admin_id") or "").strip()
    admin_name = (request.form.get("admin_name") or "").strip()

    if not admin_id or not admin_name:
        flash("Bitte ID und Namen angeben.", "danger")
        return redirect(url_for("id_finder_admin_panel"))

    admins = load_json(ADMINS_FILE, {})
    if admin_id in admins:
        flash("Admin existiert bereits.", "warning")
        return redirect(url_for("id_finder_admin_panel"))

    default_permissions = {perm: False for perm in AVAILABLE_PERMISSIONS}
    admins[admin_id] = {"name": admin_name, "permissions": default_permissions}

    save_json(ADMINS_FILE, admins)
    flash(f"Admin {admin_name} hinzugefügt.", "success")
    return redirect(url_for("id_finder_admin_panel"))


@app.route("/id-finder/delete-admin", methods=["POST"])
def id_finder_delete_admin():
    admin_id = request.form.get("admin_id")
    admins = load_json(ADMINS_FILE, {})

    if admin_id in admins:
        del admins[admin_id]
        save_json(ADMINS_FILE, admins)
        flash("Admin gelöscht.", "success")
    else:
        flash("Admin nicht gefunden.", "danger")

    return redirect(url_for("id_finder_admin_panel"))


@app.route("/id-finder/update-admin-permissions", methods=["POST"])
def id_finder_update_admin_permissions():
    admin_id = request.form.get("admin_id")
    admins = load_json(ADMINS_FILE, {})

    if admin_id not in admins:
        flash("Fehler: Admin nicht gefunden.", "danger")
        return redirect(url_for("id_finder_admin_panel"))

    new_permissions = {}
    for perm_key in AVAILABLE_PERMISSIONS:
        new_permissions[perm_key] = request.form.get(perm_key) == "on"

    admins[admin_id]["permissions"] = new_permissions
    save_json(ADMINS_FILE, admins)

    flash(f"Rechte für {admins[admin_id]['name']} aktualisiert.", "success")
    return redirect(url_for("id_finder_admin_panel"))


# --- QUIZ ROUTES ---
@app.route("/quiz-settings", methods=["GET", "POST"])
def quiz_settings():
    if request.method == "POST":
        action = request.form.get("action")

        if action == "start_quiz_bot":
            success, msg = start_quiz_bot()
            flash(msg, "success" if success else "danger")
            return redirect(url_for("quiz_settings"))

        if action == "stop_quiz_bot":
            success, msg = stop_quiz_bot()
            flash(msg, "success" if success else "danger")
            return redirect(url_for("quiz_settings"))

        if action == "save_schedule":
            cfg = load_json(QUIZ_BOT_CONFIG_FILE, {})
            current_sched = _load_schedule_from_cfg(cfg)
            cfg["schedule"] = _parse_schedule_from_form(request.form, current_sched)
            save_json(QUIZ_BOT_CONFIG_FILE, cfg)
            flash("Quiz Automatisierung gespeichert.", "success")
            return redirect(url_for("quiz_settings"))

        if action == "save_settings":
            was_running = is_quiz_bot_running()
            if was_running:
                stop_quiz_bot()

            cfg = load_json(QUIZ_BOT_CONFIG_FILE, {})
            cfg["token"] = (request.form.get("token") or "").strip()
            cfg["channel_id"] = (request.form.get("channel_id") or "").strip()
            cfg["topic_id"] = (request.form.get("topic_id") or "").strip() or None

            existing_sched = _load_schedule_from_cfg(cfg)
            time_str = _time_from_form(
                request.form,
                "quiz_time",
                fallback=existing_sched.get("time") or DEFAULT_SCHEDULE["time"],
            )

            raw_days = request.form.getlist("quiz_days")
            name_to_num = {
                "Montag": 0,
                "Dienstag": 1,
                "Mittwoch": 2,
                "Donnerstag": 3,
                "Freitag": 4,
                "Samstag": 5,
                "Sonntag": 6,
            }
            days = []
            for name in raw_days:
                num = name_to_num.get(name)
                if num is not None:
                    days.append(num)
            if not days:
                days = existing_sched.get("days", DEFAULT_SCHEDULE["days"])

            enabled = "auto_enabled" in request.form
            cfg["schedule"] = {"enabled": enabled, "time": time_str, "days": sorted(set(days))}
            save_json(QUIZ_BOT_CONFIG_FILE, cfg)
            flash("Quiz Einstellungen gespeichert.", "success")

            if was_running:
                start_quiz_bot()
                flash("Quiz Bot neu gestartet.", "info")

            return redirect(url_for("quiz_settings"))

        if action == "clear_log":
            try:
                with open(QUIZ_BOT_LOG, "w", encoding="utf-8") as f:
                    f.write("")
                flash("Quiz Bot Log geleert.", "success")
            except Exception as e:
                flash(f"Fehler beim Leeren des Quiz Bot Logs: {e}", "danger")
            return redirect(url_for("quiz_settings"))

        return redirect(url_for("quiz_settings"))

    cfg = load_json(QUIZ_BOT_CONFIG_FILE, {})
    logs = get_bot_logs(QUIZ_BOT_LOG, lines=50)
    sched = _load_schedule_from_cfg(cfg)
    next_run = _compute_next_run(sched)

    day_names = {0: "Montag", 1: "Dienstag", 2: "Mittwoch", 3: "Donnerstag", 4: "Freitag", 5: "Samstag", 6: "Sonntag"}
    cfg["quiz_time"] = sched.get("time", DEFAULT_SCHEDULE["time"])
    cfg["quiz_days"] = [day_names[d] for d in sched.get("days", []) if d in day_names]
    cfg["auto_enabled"] = bool(sched.get("enabled", False))

    return render_template(
        "quiz_settings.html",
        config={"quiz": cfg},
        logs=logs,
        is_running=is_quiz_bot_running(),
        bot_status=build_bot_status(),
        schedule=sched,
        next_run=_format_dt_de(next_run, time_first=True),
    )


