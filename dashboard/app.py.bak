# -------------------------------------------------------------------
# ✅ Minecraft Bridge/Worker Wrappers
# -------------------------------------------------------------------
def is_minecraft_bridge_running():
    return is_bot_running(minecraft_bridge_process) or is_script_running(MINECRAFT_BRIDGE_MATCH_PATTERNS)


def is_minecraft_worker_running():
    return is_bot_running(minecraft_worker_process) or is_script_running(MINECRAFT_WORKER_MATCH_PATTERNS)


def is_minecraft_status_bot_running():
    # "Bot läuft" = bridge oder worker läuft
    return is_minecraft_bridge_running() or is_minecraft_worker_running()


def start_minecraft_status_bot():
    """
    Startet Bridge + Worker (wie "ein Bot" fürs Dashboard).
    """
    global minecraft_bridge_process, minecraft_worker_process

    msgs = []
    ok = True

    if not is_minecraft_bridge_running():
        minecraft_bridge_process, msg = start_bot_process(MINECRAFT_BRIDGE_SCRIPT, MINECRAFT_BRIDGE_LOG)
        msgs.append(msg)
        ok = ok and bool(minecraft_bridge_process)
    else:
        msgs.append("Minecraft Bridge läuft bereits.")

    if not is_minecraft_worker_running():
        minecraft_worker_process, msg = start_bot_process(MINECRAFT_WORKER_SCRIPT, MINECRAFT_WORKER_LOG)
        msgs.append(msg)
        ok = ok and bool(minecraft_worker_process)
    else:
        msgs.append("Minecraft Worker läuft bereits.")

    return ok, " | ".join(msgs)


def stop_minecraft_status_bot():
    """
    Stoppt Bridge + Worker.
    """
    global minecraft_bridge_process, minecraft_worker_process

    msgs = []
    ok = True

    # zuerst Worker stoppen (postet evtl. noch)
    if minecraft_worker_process and minecraft_worker_process.poll() is None:
        minecraft_worker_process, msg = stop_bot_process(minecraft_worker_process)
        msgs.append(msg)
    else:
        success, msg = stop_script(MINECRAFT_WORKER_MATCH_PATTERNS)
        msgs.append(msg)
        ok = ok and bool(success)
        minecraft_worker_process = None

    # dann Bridge stoppen
    if minecraft_bridge_process and minecraft_bridge_process.poll() is None:
        minecraft_bridge_process, msg = stop_bot_process(minecraft_bridge_process)
        msgs.append(msg)
    else:
        success, msg = stop_script(MINECRAFT_BRIDGE_MATCH_PATTERNS)
        msgs.append(msg)
        ok = ok and bool(success)
        minecraft_bridge_process = None

    return ok, " | ".join(msgs)


# -------------------------------------------------------------------
# ✅ Telegram Proxy + Cache (Profilbilder + Media)
# -------------------------------------------------------------------
TG_CACHE_DIR = os.path.join(DATA_DIR, "tg_cache")
TG_FILES_DIR = os.path.join(TG_CACHE_DIR, "files")
TG_AVATARS_DIR = os.path.join(TG_CACHE_DIR, "avatars")
os.makedirs(TG_FILES_DIR, exist_ok=True)
os.makedirs(TG_AVATARS_DIR, exist_ok=True)
_TG_TIMEOUT = 20


def _hash_id(s: str) -> str:
    return hashlib.sha1((s or "").encode("utf-8")).hexdigest()


def _mime_for_path(path: str) -> str:
    mt, _ = mimetypes.guess_type(path)
    return mt or "application/octet-stream"


def _get_token_candidates():
    tokens = []

    try:
        cfg = load_json(ID_FINDER_CONFIG_FILE, {})
        t = (cfg.get("bot_token") or "").strip()
        if t:
            tokens.append(t)
    except Exception:
        pass

    try:
        cfg = load_json(OUTFIT_BOT_CONFIG_FILE, {})
        t = (cfg.get("BOT_TOKEN") or "").strip()
        if t:
            tokens.append(t)
    except Exception:
        pass

    try:
        cfg = load_json(INVITE_BOT_CONFIG_FILE, {})
        t = (cfg.get("bot_token") or "").strip()
        if t:
            tokens.append(t)
    except Exception:
        pass

    for fp in (QUIZ_BOT_CONFIG_FILE, UMFRAGE_BOT_CONFIG_FILE):
        try:
            cfg = load_json(fp, {})
            t = (cfg.get("token") or cfg.get("BOT_TOKEN") or cfg.get("bot_token") or "").strip()
            if t:
                tokens.append(t)
        except Exception:
            pass

    out = []
    for t in tokens:
        if t and t not in out:
            out.append(t)
    return out


def _get_primary_bot_token():
    cands = _get_token_candidates()
    return cands[0] if cands else ""


def _tg_api_call(method: str, params: dict = None, token: str = None):
    token = token or _get_primary_bot_token()
    if not token:
        return None
    try:
        base = f"https://api.telegram.org/bot{token}/{method}"
        data = urllib.parse.urlencode(params or {}).encode("utf-8")
        req = urllib.request.Request(base, data=data, method="POST")
        with urllib.request.urlopen(req, timeout=_TG_TIMEOUT) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
        obj = json.loads(raw)
        if isinstance(obj, dict) and obj.get("ok") is True:
            return obj.get("result")
        return None
    except Exception as e:
        log.warning("Telegram API call failed: %s (%s)", method, e)
        return None


def _tg_get_file_path(file_id: str, token: str = None) -> str:
    res = _tg_api_call("getFile", {"file_id": file_id}, token=token)
    if isinstance(res, dict):
        return (res.get("file_path") or "").strip()
    return ""


def _tg_download_file(file_path: str, dst_path: str, token: str = None) -> bool:
    token = token or _get_primary_bot_token()
    if not token or not file_path:
        return False
    try:
        url = f"https://api.telegram.org/file/bot{token}/{file_path}"
        req = urllib.request.Request(url, method="GET")
        with urllib.request.urlopen(req, timeout=_TG_TIMEOUT) as resp:
            data = resp.read()
        os.makedirs(os.path.dirname(dst_path), exist_ok=True)
        with open(dst_path, "wb") as f:
            f.write(data)
        return True
    except Exception as e:
        log.warning("Telegram file download failed: %s (%s)", file_path, e)
        return False


def _guess_ext_from_path(file_path: str) -> str:
    try:
        ext = os.path.splitext(file_path or "")[1].strip()
        if ext and len(ext) <= 8:
            return ext
    except Exception:
        pass
    return ".bin"


def _file_meta_path(hash_key: str) -> str:
    return os.path.join(TG_FILES_DIR, f"{hash_key}.json")


def _file_data_path(hash_key: str, ext: str) -> str:
    return os.path.join(TG_FILES_DIR, f"{hash_key}{ext}")


def _avatar_meta_path(user_id: str) -> str:
    return os.path.join(TG_AVATARS_DIR, f"{user_id}.json")


def _avatar_data_path(user_id: str, ext: str) -> str:
    return os.path.join(TG_AVATARS_DIR, f"{user_id}{ext}")


def _ensure_cached_telegram_file(file_id: str) -> str:
    file_id = (file_id or "").strip()
    if not file_id:
        return ""

    h = _hash_id(file_id)
    meta_fp = _file_meta_path(h)
    meta = load_json(meta_fp, {}) if os.path.exists(meta_fp) else {}

    ext = meta.get("ext") if isinstance(meta, dict) else None
    file_path = meta.get("file_path") if isinstance(meta, dict) else None

    if not ext or not file_path:
        token = _get_primary_bot_token()
        if not token:
            return ""
        file_path = _tg_get_file_path(file_id, token=token)
        if not file_path:
            return ""
        ext = _guess_ext_from_path(file_path)
        meta = {
            "file_id": file_id,
            "file_path": file_path,
            "ext": ext,
            "updated_at": datetime.utcnow().isoformat() + "Z",
        }
        save_json(meta_fp, meta)

    data_fp = _file_data_path(h, ext)
    if not os.path.exists(data_fp) or os.path.getsize(data_fp) == 0:
        ok = _tg_download_file(file_path, data_fp)
        if not ok:
            return ""

    return data_fp


def _ensure_cached_avatar(user_id: str) -> str:
    uid = _safe_int(user_id, None)
    if uid is None:
        return ""

    meta_fp = _avatar_meta_path(str(uid))
    meta = load_json(meta_fp, {}) if os.path.exists(meta_fp) else {}

    ext = meta.get("ext") if isinstance(meta, dict) else None
    file_path = meta.get("file_path") if isinstance(meta, dict) else None

    if not ext or not file_path:
        token = _get_primary_bot_token()
        if not token:
            return ""

        res = _tg_api_call("getUserProfilePhotos", {"user_id": uid, "limit": 1}, token=token)
        if not isinstance(res, dict):
            return ""

        photos = res.get("photos") or []
        if not photos or not isinstance(photos, list):
            return ""

        sizes = photos[0]
        if not sizes or not isinstance(sizes, list):
            return ""

        best = sizes[-1] if sizes else None
        file_id = (best or {}).get("file_id") if isinstance(best, dict) else ""
        file_id = (file_id or "").strip()
        if not file_id:
            return ""

        file_path = _tg_get_file_path(file_id, token=token)
        if not file_path:
            return ""

        ext = _guess_ext_from_path(file_path)
        meta = {
            "user_id": str(uid),
            "file_id": file_id,
            "file_path": file_path,
            "ext": ext,
            "updated_at": datetime.utcnow().isoformat() + "Z",
        }
        save_json(meta_fp, meta)

    data_fp = _avatar_data_path(str(uid), ext)
    if not os.path.exists(data_fp) or os.path.getsize(data_fp) == 0:
        ok = _tg_download_file(file_path, data_fp)
        if not ok:
            return ""

    return data_fp


# --- Telegram Proxy Routes ---
@app.route("/tg/file/<file_id>")
def tg_file_proxy(file_id):
    file_id = (file_id or "").strip()
    if not file_id:
        return abort(404)

    local_fp = _ensure_cached_telegram_file(file_id)
    if not local_fp:
        return abort(404)

    return send_file(local_fp, mimetype=_mime_for_path(local_fp), conditional=True)


@app.route("/tg/avatar/<user_id>")
def tg_avatar_proxy(user_id):
    user_id = (user_id or "").strip()
    if not user_id:
        return abort(404)

    local_fp = _ensure_cached_avatar(user_id)
    if not local_fp:
        return abort(404)

    return send_file(local_fp, mimetype=_mime_for_path(local_fp), conditional=True)


# -------------------------------------------------------------------
# ✅ Minecraft: Config + Live Status (für src/minecraft_status.html)
# -------------------------------------------------------------------

# ✅ Cache-Datei, die minecraft_bridge.py regelmäßig schreibt
MINECRAFT_STATUS_CACHE_FILE = os.path.join(DATA_DIR, "minecraft_status_cache.json")


def load_minecraft_status_cfg():
    """
    Lädt minecraft_status_config.json und migriert ältere Keys automatisch.
    """
    raw = load_json(MINECRAFT_STATUS_CONFIG_FILE, DEFAULT_MINECRAFT_STATUS_CFG.copy())
    if not isinstance(raw, dict):
        raw = {}

    # -------------------------
    # Migration alt -> neu
    # -------------------------
    if "host" in raw and "mc_host" not in raw:
        raw["mc_host"] = raw.get("host")

    if "port" in raw and "mc_port" not in raw:
        raw["mc_port"] = raw.get("port")

    # -------------------------
    # Merge mit Defaults
    # -------------------------
    cfg = DEFAULT_MINECRAFT_STATUS_CFG.copy()
    cfg.update(raw)

    # -------------------------
    # Normalisierung / Typen
    # -------------------------
    cfg["mc_host"] = str(cfg.get("mc_host") or "").strip() or DEFAULT_MINECRAFT_STATUS_CFG["mc_host"]

    cfg["mc_port"] = (
        _safe_int(cfg.get("mc_port"), DEFAULT_MINECRAFT_STATUS_CFG["mc_port"])
        or DEFAULT_MINECRAFT_STATUS_CFG["mc_port"]
    )

    cfg["display_host"] = str(cfg.get("display_host") or "").strip()
    cfg["display_port"] = (
        _safe_int(cfg.get("display_port"), cfg["mc_port"])
        or cfg["mc_port"]
    )

    cfg["chat_id"] = str(cfg.get("chat_id") or "").strip()
    cfg["topic_id"] = str(cfg.get("topic_id") or "").strip()

    cfg["update_seconds"] = (
        _safe_int(cfg.get("update_seconds"), DEFAULT_MINECRAFT_STATUS_CFG["update_seconds"])
        or DEFAULT_MINECRAFT_STATUS_CFG["update_seconds"]
    )
    cfg["update_seconds"] = max(5, min(cfg["update_seconds"], 3600))

    cfg["delete_player_seconds"] = (
        _safe_int(cfg.get("delete_player_seconds"), DEFAULT_MINECRAFT_STATUS_CFG["delete_player_seconds"])
        or DEFAULT_MINECRAFT_STATUS_CFG["delete_player_seconds"]
    )
    cfg["delete_player_seconds"] = max(0, min(cfg["delete_player_seconds"], 600))

    cfg["status_message_id"] = str(cfg.get("status_message_id") or "").strip()
    cfg["bot_token"] = str(cfg.get("bot_token") or "").strip()

    cfg["pi_host"] = str(cfg.get("pi_host") or "").strip()
    cfg["pi_ssh_port"] = (
        _safe_int(cfg.get("pi_ssh_port"), DEFAULT_MINECRAFT_STATUS_CFG["pi_ssh_port"])
        or DEFAULT_MINECRAFT_STATUS_CFG["pi_ssh_port"]
    )
    cfg["pi_ssh_user"] = str(cfg.get("pi_ssh_user") or "").strip()

    return cfg


def _mc_port_check(host: str, port: int, timeout: float = 2.0):
    """
    Minimaler Check: TCP-Port erreichbar = "online".
    (Fallback, falls Cache noch nicht vorhanden ist.)
    """
    t0 = time.time()
    try:
        with socket.create_connection((host, int(port)), timeout=float(timeout)):
            ms = int((time.time() - t0) * 1000)
            return True, ms, None
    except Exception as e:
        return False, None, str(e)


def _tail_text_file(path: str, max_lines: int = 400) -> list:
    if not os.path.exists(path):
        return []
    try:
        with open(path, "rb") as f:
            f.seek(0, os.SEEK_END)
            size = f.tell()
            block = 4096
            data = b""
            lines = []
            while size > 0 and len(lines) <= (max_lines + 50):
                step = block if size >= block else size
                size -= step
                f.seek(size)
                data = f.read(step) + data
                lines = data.splitlines()
                if len(lines) >= (max_lines + 5):
                    break
            tail = lines[-max_lines:] if max_lines > 0 else lines
            return [x.decode("utf-8", errors="replace") for x in tail]
    except Exception:
        try:
            with open(path, "r", encoding="utf-8") as f:
                return f.readlines()[-max_lines:]
        except Exception:
            return []


def load_minecraft_status_cache() -> dict:
    """
    Liest den Status aus data/minecraft_status_cache.json (wird von minecraft_bridge.py geschrieben).
    """
    raw = load_json(MINECRAFT_STATUS_CACHE_FILE, {})
    return raw if isinstance(raw, dict) else {}


def _build_minecraft_template_payload():
    """
    Baut alle Werte zusammen, damit minecraft_status.html NICHT crasht.
    Priorität: Cache (vom Bridge) -> Fallback Port-Check.
    """
    cfg = load_minecraft_status_cfg()

    cache = load_minecraft_status_cache()

    # --- Server Online/Offline + Details bevorzugt aus Cache ---
    if cache:
        server_online = bool(cache.get("server_online", False))
        ping_ms = cache.get("ping_ms")
        error = cache.get("error")
        last_update = cache.get("last_update") or _format_dt_de(_now(), time_first=True)

        status = {
            "last_update": last_update,
            "players": cache.get("players"),
            "player_count": cache.get("player_count"),
            "max_players": cache.get("max_players"),
            "online_names": cache.get("online_names") or [],
            "version": cache.get("version"),
            "software": cache.get("software"),
            "motd": cache.get("motd"),
            "ping_ms": ping_ms,
            "error": error,
        }
    else:
        # Fallback: Port check, falls Bridge noch nie gelaufen ist
        server_online, ping_ms, error = _mc_port_check(cfg["mc_host"], cfg["mc_port"], timeout=2.0)
        status = {
            "last_update": _format_dt_de(_now(), time_first=True),
            "players": None,
            "player_count": None,
            "max_players": None,
            "online_names": [],
            "version": None,
            "software": None,
            "motd": None,
            "ping_ms": ping_ms,
            "error": error if (error and not server_online) else None,
        }

    # Raspberry Pi Metrics (Platzhalter – später via SSH/Exporter)
    pi = {
        "host": cfg.get("pi_host") or "",
        "cpu_percent": None,
        "ram_used_mb": None,
        "ram_total_mb": None,
        "ram_percent": None,
        "temp_c": None,
        "uptime": None,
        "disk_used_gb": None,
        "disk_total_gb": None,
        "disk_percent": None,
        "load1": None,
        "load5": None,
        "load15": None,
    }

    # Logs (Bridge + Worker kombiniert)
    bridge_tail = _tail_text_file(MINECRAFT_BRIDGE_LOG, max_lines=180)
    worker_tail = _tail_text_file(MINECRAFT_WORKER_LOG, max_lines=180)

    parts = []
    if bridge_tail:
        parts.append("===== minecraft_bridge.log =====")
        parts.extend(bridge_tail)
    if worker_tail:
        parts.append("\n===== minecraft_worker.log =====")
        parts.extend(worker_tail)

    log_tail = "\n".join(parts).strip() or "—"
    log_path = f"{MINECRAFT_BRIDGE_LOG} | {MINECRAFT_WORKER_LOG}"

    is_running = is_minecraft_status_bot_running()

    # Für später: Minecraft-Server Start/Stop (nicht aktiv, solange keine Routes existieren)
    enable_server_control = False

    return {
        "cfg": cfg,
        "status": status,
        "server_online": server_online,
        "is_running": is_running,
        "pi": pi,
        "log_path": log_path,
        "log_tail": log_tail,
        "enable_server_control": enable_server_control,
    }


# -------------------------------------------------------------------
# ✅ Minecraft Routes: Endpoints müssen GENAU so heißen wie im Template!
# -------------------------------------------------------------------
@app.route("/minecraft", methods=["GET"], endpoint="minecraft_status_page")
def minecraft_status_page():
    payload = _build_minecraft_template_payload()
    return render_template(
        "minecraft_status.html",
        cfg=payload["cfg"],
        status=payload["status"],
        server_online=payload["server_online"],
        is_running=payload["is_running"],
        pi=payload["pi"],
        log_path=payload["log_path"],
        log_tail=payload["log_tail"],
        enable_server_control=payload["enable_server_control"],
        bot_status=build_bot_status(),
    )


@app.route("/minecraft/start", methods=["POST"], endpoint="minecraft_status_start")
def minecraft_status_start():
    ok, msg = start_minecraft_status_bot()
    flash(msg, "success" if ok else "danger")
    return redirect(url_for("minecraft_status_page"))


@app.route("/minecraft/stop", methods=["POST"], endpoint="minecraft_status_stop")
def minecraft_status_stop():
    ok, msg = stop_minecraft_status_bot()
    flash(msg, "success" if ok else "danger")
    return redirect(url_for("minecraft_status_page"))


@app.route("/minecraft/save", methods=["POST"], endpoint="minecraft_status_save")
def minecraft_status_save():
    was_running = is_minecraft_status_bot_running()
    if was_running:
        stop_minecraft_status_bot()

    cfg = load_minecraft_status_cfg()
    form = request.form

    # Interne Abfrage
    cfg["mc_host"] = (form.get("mc_host") or cfg.get("mc_host") or "").strip()
    cfg["mc_port"] = _safe_int(form.get("mc_port"), cfg.get("mc_port") or 25565) or (cfg.get("mc_port") or 25565)

    # Anzeige
    cfg["display_host"] = (form.get("display_host") or cfg.get("display_host") or "").strip()
    cfg["display_port"] = _safe_int(form.get("display_port"), cfg.get("display_port") or cfg["mc_port"]) or (cfg.get("display_port") or cfg["mc_port"])

    # Telegram
    cfg["chat_id"] = (form.get("chat_id") or cfg.get("chat_id") or "").strip()
    cfg["topic_id"] = (form.get("topic_id") or cfg.get("topic_id") or "").strip()

    # Intervalle
    cfg["update_seconds"] = _safe_int(form.get("update_seconds"), cfg.get("update_seconds") or 30) or (cfg.get("update_seconds") or 30)
    if cfg["update_seconds"] < 5:
        cfg["update_seconds"] = 5
    if cfg["update_seconds"] > 3600:
        cfg["update_seconds"] = 3600

    cfg["delete_player_seconds"] = _safe_int(form.get("delete_player_seconds"), cfg.get("delete_player_seconds") or 8)
    if cfg["delete_player_seconds"] is None:
        cfg["delete_player_seconds"] = cfg.get("delete_player_seconds") or 8
    if cfg["delete_player_seconds"] < 0:
        cfg["delete_player_seconds"] = 0
    if cfg["delete_player_seconds"] > 600:
        cfg["delete_player_seconds"] = 600

    # Status Message ID (readonly im UI – aber speichern wir trotzdem den aktuellen Wert)
    cfg["status_message_id"] = (form.get("status_message_id") or cfg.get("status_message_id") or "").strip()

    # optional Bot Token
    token_in = (form.get("bot_token") or "").strip()
    if token_in:
        cfg["bot_token"] = token_in  # nur überschreiben, wenn gesetzt

    # Raspberry Pi SSH (optional)
    cfg["pi_host"] = (form.get("pi_host") or cfg.get("pi_host") or "").strip()
    cfg["pi_ssh_port"] = _safe_int(form.get("pi_ssh_port"), cfg.get("pi_ssh_port") or 22) or (cfg.get("pi_ssh_port") or 22)
    cfg["pi_ssh_user"] = (form.get("pi_ssh_user") or cfg.get("pi_ssh_user") or "").strip()

    save_json(MINECRAFT_STATUS_CONFIG_FILE, cfg)
    flash("Minecraft Status Einstellungen gespeichert ✅", "success")

    if was_running:
        start_minecraft_status_bot()
        flash("Minecraft Status Bot wurde neu gestartet 🔄", "info")

    return redirect(url_for("minecraft_status_page"))


