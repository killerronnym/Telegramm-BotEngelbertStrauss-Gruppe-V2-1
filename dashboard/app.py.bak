        status=payload["status"],
        server_online=payload["server_online"],
        is_running=payload["is_running"],
        pi=payload["pi"],
        log_path=payload["log_path"],
        log_tail=payload["log_tail"],
        enable_server_control=payload["enable_server_control"],
        bot_status=build_bot_status(),
    )


