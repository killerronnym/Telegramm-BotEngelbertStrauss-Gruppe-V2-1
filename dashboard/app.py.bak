# --- JSON Helpers ---
def load_json(file_path, default_data=None):
    if default_data is None:
        default_data = {}
    if not os.path.exists(file_path) or os.path.getsize(file_path) == 0:
        return default_data
    try:
        with open(file_path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception as e:
        log.warning("JSON konnte nicht geladen werden: %s (%s)", file_path, e)
        return default_data


def save_json(file_path, data):
    os.makedirs(os.path.dirname(file_path), exist_ok=True)
    with open(file_path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=4, ensure_ascii=False)


def _safe_int(v, default=None):
    try:
        return int(str(v).strip())
    except Exception:
        return default


def _safe_int_or_none(v):
    """
    Erlaubt auch negative IDs (Telegram Chats), sonst None.
    """
    if v is None:
        return None
    s = str(v).strip()
    if not s:
        return None
    if re.match(r"^-?\d+$", s):
        try:
            return int(s)
        except Exception:
            return None
    return None


def _safe_str(v, default=""):
    if v is None:
        return default
    return str(v)


def _form_bool(form, key: str, default: bool = False) -> bool:
    """
    Robust für Checkboxen:
    - unterstützt Hidden-Input (0) + Checkbox (1) mit gleichem Namen
    - nutzt getlist() und wertet den "letzten sinnvollen" Wert aus
    """
    try:
        if key not in form:
            return default

        vals = []
        try:
            vals = form.getlist(key)
        except Exception:
            vals = [form.get(key)]

        truthy = {"1", "true", "on", "yes", "y", "ja"}
        falsy = {"0", "false", "off", "no", "n", "nein"}

        for v in reversed(vals):
            if v is None:
                continue
            s = str(v).strip().lower()
            if s in truthy:
                return True
            if s in falsy:
                return False

        return True
    except Exception:
        return default


def _checkbox(form, key: str) -> bool:
    return _form_bool(form, key, default=False)


def _apply_checkbox_tristate(config: dict, form, key: str, *, default_if_missing: bool):
    """
    Fix für Checkbox-Felder, die evtl. im Template (noch) nicht existieren.
    """
    present_flag = "message_logging_form_present"
    form_supports = (present_flag in form) or any(
        k in form
        for k in [
            "message_logging_enabled",
            "message_logging_groups_only",
            "message_logging_ignore_commands",
            "message_logging_ignore_bots",
        ]
    )

    if form_supports and (key in form or present_flag in form):
        config[key] = _form_bool(form, key, default=bool(config.get(key, default_if_missing)))
    elif form_supports and any(
        k in form
        for k in [
            "message_logging_enabled",
            "message_logging_groups_only",
            "message_logging_ignore_commands",
            "message_logging_ignore_bots",
        ]
    ):
        config[key] = _form_bool(form, key, default=bool(config.get(key, default_if_missing)))
    else:
        config[key] = bool(config.get(key, default_if_missing))


# ✅ NEU: Robust Time Parser (HH:MM oder separate Felder *_hour + *_minute)
def _normalize_hhmm(t: str, fallback: str = "19:00") -> str:
    t = (t or "").strip()
    if not re.match(r"^\d{2}:\d{2}$", t):
        return fallback
    hh, mm = t.split(":")
    if not (hh.isdigit() and mm.isdigit()):
        return fallback
    hhi, mmi = int(hh), int(mm)
    if not (0 <= hhi <= 23 and 0 <= mmi <= 59):
        return fallback
    return f"{hhi:02d}:{mmi:02d}"


def _time_from_form(form, base_key: str, fallback: str = "19:00") -> str:
    direct = (form.get(base_key) or "").strip()
    if direct:
        return _normalize_hhmm(direct, fallback=fallback)

    h = form.get(f"{base_key}_hour")
    m = form.get(f"{base_key}_minute") or form.get(f"{base_key}_min")

    if h is None and m is None:
        alt_prefix = base_key.replace("_time", "")
        h = form.get(f"{alt_prefix}_hour") or form.get("hour")
        m = form.get(f"{alt_prefix}_minute") or form.get(f"{alt_prefix}_min") or form.get("minute")

    hi = _safe_int(h, None)
    mi = _safe_int(m, None)
    if hi is None or mi is None:
        return _normalize_hhmm("", fallback=fallback)

    if not (0 <= hi <= 23 and 0 <= mi <= 59):
        return _normalize_hhmm("", fallback=fallback)

    return f"{hi:02d}:{mi:02d}"


# ✅ Admin-Permissions Migration
def migrate_admins_permissions():
    try:
        admins = load_json(ADMINS_FILE, {})
        if not isinstance(admins, dict):
            return

        changed = False

        legacy_map = {
            "can_manage_messages": ["can_delete_messages", "can_pin_messages", "can_configure"],
            "can_config": ["can_configure"],
            "can_clear_warns": ["can_warn"],
        }

        for admin_id, entry in admins.items():
            if not isinstance(entry, dict):
                continue
            perms = entry.get("permissions", {})
            if not isinstance(perms, dict):
                perms = {}
                entry["permissions"] = perms
                changed = True

            for old_key, new_keys in legacy_map.items():
                if perms.get(old_key) is True:
                    for nk in new_keys:
                        if perms.get(nk) is not True:
                            perms[nk] = True
                            changed = True

            for key in AVAILABLE_PERMISSIONS.keys():
                if key not in perms:
                    perms[key] = False
                    changed = True

        if changed:
            save_json(ADMINS_FILE, admins)
            log.info("admins.json Permissions migriert/ergänzt.")
    except Exception as e:
        log.warning("Admins-Permissions Migration fehlgeschlagen: %s", e)


# ✅ Helper: last_seen robust parsen (für Analytics)
def _parse_dt(s):
    if not s:
        return None
    try:
        ss = str(s).strip()
        if ss.endswith("Z"):
            ss = ss.replace("Z", "+00:00")
        return datetime.fromisoformat(ss)
    except Exception:
        return None


# --- Scheduler (Quiz/Umfrage Trigger) ---
TZ = None
if ZoneInfo:
    try:
        TZ = ZoneInfo("Europe/Berlin")
    except Exception:
        TZ = None

DEFAULT_SCHEDULE = {"enabled": False, "time": "19:00", "days": [0, 1, 2, 3, 4]}
_last_fired = {}


def _now():
    return datetime.now(TZ) if TZ else datetime.now()


def _to_local(dt: datetime):
    if not dt:
        return None
    try:
        if TZ and dt.tzinfo is not None:
            return dt.astimezone(TZ)
        return dt
    except Exception:
        return dt


def _format_dt_de(dt, *, time_first: bool = True):
    if not dt:
        return None
    dt = _to_local(dt)
    wd = {0: "Mo", 1: "Di", 2: "Mi", 3: "Do", 4: "Fr", 5: "Sa", 6: "So"}
    try:
        if time_first:
            return f"{wd.get(dt.weekday(), '')}, {dt.strftime('%H:%M')} Uhr · {dt.strftime('%d.%m.%Y')}"
        return f"{wd.get(dt.weekday(), '')}, {dt.strftime('%d.%m.%Y %H:%M')} Uhr"
    except Exception:
        return str(dt)


def _load_schedule_from_cfg(cfg: dict) -> dict:
    sched = cfg.get("schedule") if isinstance(cfg, dict) else None
    if not isinstance(sched, dict):
        return DEFAULT_SCHEDULE.copy()

    enabled = bool(sched.get("enabled", False))
    t = _normalize_hhmm(str(sched.get("time", DEFAULT_SCHEDULE["time"])).strip(), fallback=DEFAULT_SCHEDULE["time"])

    days = sched.get("days", DEFAULT_SCHEDULE["days"])
    if isinstance(days, list):
        norm_days = []
        for d in days:
            try:
                di = int(d)
                if 0 <= di <= 6:
                    norm_days.append(di)
            except Exception:
                pass
        days = sorted(set(norm_days))
    else:
        days = DEFAULT_SCHEDULE["days"]

    if not days:
        days = DEFAULT_SCHEDULE["days"]

    return {"enabled": enabled, "time": t, "days": days}


def _parse_schedule_from_form(form, fallback_sched: dict) -> dict:
    enabled = "schedule_enabled" in form
    t = _time_from_form(form, "schedule_time", fallback=fallback_sched.get("time") or DEFAULT_SCHEDULE["time"])

    raw_days = form.getlist("schedule_days")
    days = []
    for x in raw_days:
        try:
            xi = int(x)
            if 0 <= xi <= 6:
                days.append(xi)
        except Exception:
            pass

    if not days:
        days = fallback_sched.get("days") or DEFAULT_SCHEDULE["days"]

    return {"enabled": enabled, "time": t, "days": sorted(set(days))}


def _compute_next_run(sched: dict):
    if not sched.get("enabled"):
        return None
    days = sched.get("days") or []
    if not days:
        return None

    hh, mm = sched.get("time", "19:00").split(":")
    target_h, target_m = int(hh), int(mm)

    now = _now()

    for i in range(0, 8):
        day = now.date() + timedelta(days=i)
        cand = (
            datetime(day.year, day.month, day.day, target_h, target_m, tzinfo=TZ)
            if TZ
            else datetime(day.year, day.month, day.day, target_h, target_m)
        )
        if cand.weekday() in days and cand > now + timedelta(seconds=15):
            return cand
    return None


def write_trigger(trigger_path, content="trigger"):
    os.makedirs(os.path.dirname(trigger_path), exist_ok=True)
    with open(trigger_path, "w", encoding="utf-8") as f:
        f.write(content)


def _maybe_fire(bot_name: str, cfg_file: str, trigger_path: str, is_running_fn):
    cfg = load_json(cfg_file, {})
    sched = _load_schedule_from_cfg(cfg)

    if not sched.get("enabled"):
        return

    now = _now()

    if now.weekday() not in (sched.get("days") or []):
        return
    if now.strftime("%H:%M") != sched.get("time"):
        return

    key = now.strftime("%Y-%m-%d %H:%M")
    if _last_fired.get(bot_name) == key:
        return

    if not is_running_fn():
        log.warning("Scheduler: %s wäre fällig (%s), aber Bot läuft nicht.", bot_name, key)
        _last_fired[bot_name] = key
        return

    try:
        write_trigger(trigger_path)
        log.info("Scheduler: Trigger für %s geschrieben (%s).", bot_name, key)
    except Exception as e:
        log.error("Scheduler: Fehler beim Trigger für %s: %s", bot_name, e)

    _last_fired[bot_name] = key


def scheduler_loop():
    log.info("Scheduler-Thread gestartet (TZ=%s).", "Europe/Berlin" if TZ else "LOCAL/NAIV")
    while True:
        try:
            _maybe_fire(
                "quiz",
                QUIZ_BOT_CONFIG_FILE,
                os.path.join(QUIZ_BOT_DIR, "command_send_random.tmp"),
                is_quiz_bot_running,
            )
            _maybe_fire(
                "umfrage",
                UMFRAGE_BOT_CONFIG_FILE,
                os.path.join(UMFRAGE_BOT_DIR, "command_send_random.tmp"),
                is_umfrage_bot_running,
            )
        except Exception as e:
            log.error("Scheduler-Loop Fehler: %s", e)
        time.sleep(10)


def start_scheduler_thread():
    t = threading.Thread(target=scheduler_loop, daemon=True)
    t.start()
    return t


# --- Prozess/Status Helpers ---
def is_bot_running(process):
    return process is not None and process.poll() is None


def _normalize_patterns(patterns):
    if patterns is None:
        return []
    if isinstance(patterns, (list, tuple, set)):
        return [str(p) for p in patterns if p]
    return [str(patterns)]


def find_pids(patterns):
    pats = _normalize_patterns(patterns)
    if not pats:
        return []
    try:
        if shutil.which("pgrep"):
            pids = []
            for p in pats:
                r = subprocess.run(["pgrep", "-f", p], stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True)
                pids.extend([int(x) for x in r.stdout.split() if x.strip().isdigit()])
            return sorted(set(pids))

        r = subprocess.run(["ps", "auxww"], stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True)
        pids = []
        for line in r.stdout.splitlines():
            if "grep" in line:
                continue
            if any(p in line for p in pats):
                parts = line.split()
                if len(parts) > 1 and parts[1].isdigit():
                    pids.append(int(parts[1]))
        return sorted(set(pids))
    except Exception:
        return []


def is_script_running(patterns) -> bool:
    return len(find_pids(patterns)) > 0


def stop_script(patterns):
    pats = _normalize_patterns(patterns)
    if not pats:
        return True, "Bot erfolgreich gestoppt."
    try:
        if shutil.which("pkill"):
            for p in pats:
                subprocess.run(["pkill", "-f", p], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True, "Bot erfolgreich gestoppt."
        for pid in find_pids(pats):
            try:
                os.kill(pid, signal.SIGTERM)
            except Exception:
                pass
        return True, "Bot erfolgreich gestoppt."
    except Exception as e:
        return False, f"Fehler beim Stoppen: {e}"


def get_bot_logs(log_file, lines=100):
    if not os.path.exists(log_file):
        return [f"Keine Log-Datei vorhanden unter: {log_file}"]
    try:
        with open(log_file, "r", encoding="utf-8") as f:
            return list(reversed(f.readlines()[-lines:]))
    except Exception as e:
        return [f"Fehler beim Lesen der Logs ({log_file}): {e}"]


def start_bot_process(script_path, log_path):
    try:
        if not os.path.exists(script_path):
            return None, f"Script nicht gefunden: {script_path}"
        cwd = os.path.dirname(script_path)
        py_exec = sys.executable
        os.makedirs(os.path.dirname(log_path), exist_ok=True)
        with open(log_path, "a", encoding="utf-8") as log_f:
            process = subprocess.Popen(
                [py_exec, script_path],
                cwd=cwd,
                stdout=log_f,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
                universal_newlines=True,
            )
        return process, f"{os.path.basename(script_path)} erfolgreich gestartet."
    except Exception as e:
        return None, str(e)


def stop_bot_process(process):
    if not process or process.poll() is not None:
        return None, "Bot läuft nicht."
    try:
        process.terminate()
        process.wait(timeout=5)
    except subprocess.TimeoutExpired:
        process.kill()
    return None, "Bot erfolgreich gestoppt."


def _safe_pid_from_process(proc):
    try:
        if proc and proc.poll() is None:
            return proc.pid
    except Exception:
        pass
    return None


def build_bot_status():
    global outfit_bot_process, id_finder_process, invite_bot_process, quiz_bot_process, umfrage_bot_process
    global minecraft_bridge_process, minecraft_worker_process

    proc_map = {
        "outfit": outfit_bot_process,
        "id_finder": id_finder_process,
        "invite": invite_bot_process,
        "quiz": quiz_bot_process,
        "umfrage": umfrage_bot_process,

        # ✅ Minecraft
        "minecraft_bridge": minecraft_bridge_process,
        "minecraft_worker": minecraft_worker_process,
    }
    pattern_map = {
        "outfit": OUTFIT_MATCH_PATTERNS,
        "id_finder": ID_FINDER_MATCH_PATTERNS,
        "invite": INVITE_MATCH_PATTERNS,
        "quiz": QUIZ_MATCH_PATTERNS,
        "umfrage": UMFRAGE_MATCH_PATTERNS,

        # ✅ Minecraft
        "minecraft_bridge": MINECRAFT_BRIDGE_MATCH_PATTERNS,
        "minecraft_worker": MINECRAFT_WORKER_MATCH_PATTERNS,
    }

    status = {}
    for name, proc in proc_map.items():
        proc_pid = _safe_pid_from_process(proc)
        pids = find_pids(pattern_map.get(name)) if pattern_map.get(name) else []
        running = (proc_pid is not None) or (len(pids) > 0)
        pid = proc_pid if proc_pid is not None else (pids[0] if pids else None)
        status[name] = {"running": running, "pid": pid}
    return status


# --- Bot Wrappers ---
def is_outfit_bot_running():
    return is_bot_running(outfit_bot_process) or is_script_running(OUTFIT_MATCH_PATTERNS)


