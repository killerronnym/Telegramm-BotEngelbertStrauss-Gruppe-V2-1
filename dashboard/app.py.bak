# --- SEND RANDOM (Trigger-Dateien statt direkt Telegram senden) ---
@app.route("/quiz/send-random", methods=["POST"])
def send_random_quiz_route():
    if not is_quiz_bot_running():
        flash("Quiz Bot läuft nicht! Bitte starten.", "danger")
        return redirect(url_for("quiz_settings"))

    try:
        write_trigger(os.path.join(QUIZ_BOT_DIR, "command_send_random.tmp"))
        flash("Quiz-Trigger gesendet.", "success")
    except Exception as e:
        flash(f"Fehler beim Triggern des Quiz: {e}", "danger")

    return redirect(url_for("quiz_settings"))


@app.route("/send_quizfrage", methods=["POST"])
def legacy_send_quizfrage():
    return send_random_quiz_route()


@app.route("/umfrage/send-random", methods=["POST"])
def send_random_poll_route():
    if not is_umfrage_bot_running():
        flash("Umfrage Bot läuft nicht! Bitte starten.", "danger")
        return redirect(url_for("umfrage_settings"))

    try:
        write_trigger(os.path.join(UMFRAGE_BOT_DIR, "command_send_random.tmp"))
        flash("Umfrage-Trigger gesendet.", "success")
    except Exception as e:
        flash(f"Fehler beim Triggern der Umfrage: {e}", "danger")

    return redirect(url_for("umfrage_settings"))


# --- Cleanup beim Beenden ---
def cleanup_processes():
    global outfit_bot_process, id_finder_process, invite_bot_process, quiz_bot_process, umfrage_bot_process
    global minecraft_bridge_process, minecraft_worker_process

    for proc in (
        outfit_bot_process,
        id_finder_process,
        invite_bot_process,
        quiz_bot_process,
        umfrage_bot_process,
        minecraft_bridge_process,
        minecraft_worker_process,
    ):
        try:
            if proc and proc.poll() is None:
                proc.terminate()
        except Exception:
            pass


atexit.register(cleanup_processes)


